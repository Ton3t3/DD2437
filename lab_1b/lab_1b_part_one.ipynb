        "def transfer_function(x):\n",
        "  return 2/(1+np.exp(-x))-1\n",
        "\n",
        "def der_transfer_function(x):\n",
        "  phi = transfer_function(x)\n",
        "  return (1+phi)*(1-phi)/2"
      ]
